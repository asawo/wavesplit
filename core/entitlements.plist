<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required for yt-dlp (PyInstaller): allows loading the bundled Python.framework
         which has the original yt-dlp developers' Team ID, different from our ad-hoc signature. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Required for yt-dlp to make outbound network requests (YouTube downloads)
         when hardened runtime is enabled. -->
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>
